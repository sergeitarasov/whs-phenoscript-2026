        .unit: unit-millimeter
    #<<<YAML

	
    this > aism-mid_leg:id-2c55e8;
    
    #>>>YAML relative_measurement
    relative_measurement:
        .measured_trait:
            .entity: aism-fore_leg:id-80ef54
            .quality: pato-length
        .unit:
